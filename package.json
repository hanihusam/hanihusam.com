{
  "name": "hanihusam.com",
  "version": "1.3.0",
  "engines": {
    "node": ">=22.22.0"
  },
  "type": "module",
  "sideEffects": false,
  "description": "A source code of hanihusam.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanihusam/hanihusam.com.git"
  },
  "keywords": [],
  "author": "Hani Husamuddin <hi@hanihusam.com> (https://hanihusam.com/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hanihusam/hanihusam.com/issues"
  },
  "homepage": "https://github.com/hanihusam/hanihusam.com#readme",
  "scripts": {
    "build": "run-s build:*",
    "build:rr": "react-router build",
    "build:info": "node ./other/build-info.js",
    "dev": "cross-env NODE_ENV=development node server.js",
    "setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "start": "cross-env NODE_ENV=production node server.js",
    "curl:blog": "curl --HEAD --silent http://localhost:$PORT/blog > /dev/null || true",
    "prime-cache:prod": "cross-env PORT=4001 npx start-server-and-test start http-get://localhost:4001/build/info.json curl:blog && echo cache primed ⚡️",
    "prime-cache:mocks": "cross-env PORT=4001 npx start-server-and-test start:mocks http-get://localhost:4001/build/info.json curl:blog && echo cache primed ⚡️",
    "test": "vitest",
    "test:e2e:dev": "start-server-and-test dev http://localhost:3000 \"npx cypress open\"",
    "pretest:e2e:run": "npm run build",
    "test:e2e:run": "cross-env PORT=8811 start-server-and-test start:mocks http://localhost:8811 \"npx cypress run\"",
    "lint": "eslint --ignore-pattern .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint --fix && npm run format",
    "lint:strict": "eslint --max-warnings=0 src",
    "format": "prettier --write \"**/*.+(js|jsx|json|yml|yaml|css|less|scss|ts|tsx|md|gql|graphql|mdx|vue)\"",
    "typecheck": "react-router typegen && tsc",
    "validate": "./other/validate"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@cld-apis/types": "^0.1.6",
    "@conform-to/zod": "^1.19.3",
    "@epic-web/cachified": "^5.2.0",
    "@epic-web/client-hints": "^1.3.9",
    "@epic-web/config": "^1.16.5",
    "@epic-web/invariant": "^1.0.0",
    "@epic-web/remember": "^1.1.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@octokit/plugin-throttling": "^10.0.0",
    "@octokit/rest": "^21.1.0",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/fs-routes": "^7.15.1",
    "@react-router/node": "^7.15.1",
    "@react-router/serve": "^7.15.1",
    "better-sqlite3": "^11.9.1",
    "chalk": "^5.0.0",
    "chokidar": "^4.0.3",
    "cloudinary-build-url": "^0.2.4",
    "clsx": "^2.1.1",
    "compression": "^1.7.5",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.28.1",
    "execa": "^9.5.2",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.9.3",
    "gray-matter": "^4.0.3",
    "isbot": "^5.1.22",
    "litefs-js": "^1.1.2",
    "lru-cache": "^11.0.2",
    "match-sorter": "^8.0.0",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mdx-bundler": "^10.0.3",
    "morgan": "^1.10.0",
    "motion": "^12.38.0",
    "p-queue": "^8.1.0",
    "prisma": "^6.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^3.4.0",
    "source-map-support": "^0.5.21",
    "tailwind-merge": "^3.0.1",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@faker-js/faker": "^9.4.0",
    "@react-router/dev": "^7.15.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/source-map-support": "^0.5.10",
    "@typescript-eslint/utils": "^8.23.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-c8": "^0.33.0",
    "cookie": "^1.1.1",
    "esbuild-register": "^3.6.0",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "msw": "^2.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vite-env-only": "^3.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss",
      "@epic-web/config/prettier"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix",
      "prettier -w"
    ],
    "*.{json,css,scss,md,mdx}": [
      "prettier -w"
    ]
  }
}
